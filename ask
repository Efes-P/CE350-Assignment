#!/bin/bash

if [[ -z "$ASK_API_URL" || -z "$ASK_MODEL" || -z "$ASK_API_KEY" ]]; then
    echo "Error: ASK_API_URL, ASK_MODEL, and ASK_API_KEY must be set."
    exit 1
fi

PIPE_INPUT=""
if [[ ! -t 0 ]]; then
    PIPE_INPUT=$(cat)
fi

ARGS_INPUT="$*"
USER_PROMPT=$(printf "%s\n%s" "$PIPE_INPUT" "$ARGS_INPUT")

if [[ -z "$(echo -e "$USER_PROMPT" | tr -d '[:space:]')" ]]; then
    echo "Usage: ask <prompt> or echo <prompt> | ask"
    exit 1
fi

JSON_PAYLOAD=$(jq -n \
    --arg model "$ASK_MODEL" \
    --arg sys_msg "You are a CLI tool. Output plain text only. No yapping. Keep the output concise." \
    --arg user_msg "$USER_PROMPT" \
    '{
        model: $model,
        messages: [
            {role: "system", content: $sys_msg},
            {role: "user", content: $user_msg}
        ]
    }')

curl -s "$ASK_API_URL" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $ASK_API_KEY" \
    -d "$JSON_PAYLOAD" | jq -r '.choices[0].message.content'
